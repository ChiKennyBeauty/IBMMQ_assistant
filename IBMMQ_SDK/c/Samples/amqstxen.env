/* Edit directory paths for TUXEDO and IBM MQ install directories */

set TUXDIR   =f:\tuxedo
set APPDIR   =f:\tuxedo\apps\mqapp;g:\mqm\bin
set PATH     =f:\tuxedo\apps\mqapp;%PATH%
set TUXCONFIG=f:\tuxedo\apps\mqapp\tuxconfig
set VIEWFILES=f:\tuxedo\apps\mqapp\amqstxvx.VV
